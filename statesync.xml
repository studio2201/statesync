<?xml version="1.0"?>
<Container version="2">
  <Name>statesync</Name>
  <Repository>ghcr.io/studio2201/statesync:latest</Repository>
  <Registry>https://ghcr.io/studio2201/statesync</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/statesync/issues</Support>
  <Project>https://github.com/studio2201/statesync</Project>
  <Overview>Sync watched status, resume position, and favorites across Emby and Jellyfin.</Overview>
  <Category>MediaApp:Video MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:4601]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/statesync.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/statesync.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Sync watched status, resume position, and favorites across Emby and Jellyfin.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4601</HostPort>
        <ContainerPort>4601</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/statesync</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4601</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4601" Default="4601" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4601</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/statesync" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/statesync</Config>
</Container>
