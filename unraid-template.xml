<?xml version="1.0"?>
<Container version="2">
  <Name>statesync</Name>
  <Repository>ubermetroid/statesync:latest</Repository>
  <Registry>https://hub.docker.com/r/ubermetroid/statesync</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/UberMetroid/statesync/issues</Support>
  <Project>https://github.com/UberMetroid/statesync</Project>
  <Overview>Lightweight, real-time playstate sync bridge between your Emby and Jellyfin servers with a Web UI dashboard on port 8754.</Overview>
  <Category>MediaApp:Video MediaApp:Other</Category>
  <Icon>https://raw.githubusercontent.com/UberMetroid/statesync/master/graphics/statesync_icon.jpg</Icon>
  <WebUI>http://[IP]:[PORT:8754]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/UberMetroid/statesync/master/unraid-template.xml</TemplateURL>
  
  <!-- Port Mapping -->
  <Config Name="WebUI Port" Target="8754" Default="8754" Mode="tcp" Description="Web interface port for the statesync dashboard." Type="Port" Display="always" Required="true" Mask="false"/>

  <!-- Volume Mapping -->
  <Config Name="Config Volume" Target="/config" Default="/mnt/user/appdata/statesync" Mode="rw" Description="Persistent directory for statesync settings and config file." Type="Path" Display="always" Required="true" Mask="false"/>

  <!-- Global Settings -->
  <Config Name="Log Level" Target="RUST_LOG" Default="info" Mode="" Description="Logging level (info, warn, error, debug)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Description="Container Timezone (e.g. America/New_York)" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
