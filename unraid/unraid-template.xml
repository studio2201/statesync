<?xml version='1.0' encoding='utf-8'?>
<Container version="2">
  <Name>statesync</Name>
  <Repository>ghcr.io/studio2201/statesync:latest</Repository>
  <Registry>https://github.com/studio2201/statesync/pkgs/container/statesync</Registry>
  <Network>bridge</Network>
  <MyIP />
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/statesync/issues</Support>
  <Project>https://github.com/studio2201/statesync</Project>
  <Overview>StateSync: watched / resume / favorites across Emby and Jellyfin. Alpine + ash console. No login. Zero required env vars.</Overview>
  <Category>MediaApp:Video MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:4601]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/statesync/master/unraid/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/statesync/master/graphics/statesync_icon.jpg</Icon>
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled />
  <DonateText />
  <DonateLink />
  <Requires />
  <Description>
StateSync is a zero-config LAN sidecar. Defaults work on bridge with only Appdata + port 4601.
Console: Shell = sh (BusyBox ash on Alpine). If Emby/Jellyfin use br0/macvlan, set this container Network to br0 so it can reach them (not localhost).
Add servers in the WebUI (URL + API key). Full browser URLs are OK — only host:port is kept.
  </Description>
  <Config Name="Web UI Port" Target="4601" Default="4601" Mode="tcp" Description="Host port mapped to container 4601." Type="Port" Display="always" Required="true" Mask="false">4601</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/statesync" Mode="rw" Description="Persists config.json." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/statesync</Config>
  <Config Name="Timezone" Target="TZ" Default="America/New_York" Mode="" Description="Optional log timestamps." Type="Variable" Display="advanced" Required="false" Mask="false">America/New_York</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="Optional UID (Unraid nobody)." Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Optional GID (Unraid users)." Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <Config Name="UMASK" Target="UMASK" Default="022" Mode="" Description="Optional file umask." Type="Variable" Display="advanced" Required="false" Mask="false">022</Config>
  <Config Name="Log Level" Target="RUST_LOG" Default="info" Mode="" Description="Optional: info or debug." Type="Variable" Display="advanced" Required="false" Mask="false">info</Config>
  <Config Name="Bind Address" Target="STATESYNC_BIND" Default="0.0.0.0:4601" Mode="" Description="Optional listen address inside container." Type="Variable" Display="advanced" Required="false" Mask="false">0.0.0.0:4601</Config>
  <Config Name="Allow HTTP to media servers" Target="STATESYNC_ALLOW_INSECURE_HTTP" Default="true" Mode="" Description="Optional; LAN http:// to Emby/Jellyfin." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="Accept Invalid TLS Certs" Target="STATESYNC_ACCEPT_INVALID_CERTS" Default="false" Mode="" Description="Optional; only for self-signed HTTPS you trust." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
</Container>
